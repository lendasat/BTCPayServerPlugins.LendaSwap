@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.LendaSwap.Plugins.Swap
@using BTCPayServer.LendaSwap.Plugins.Swap.ViewModels
@model LendaSwapSettingsViewModel
@inject IScopeProvider ScopeProvider
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
    Layout = "_Layout";
    ViewData.SetLayoutModel(new LayoutModel(nameof(LendaSwapNavPages.Settings), "LendaSwap Settings")
        { ActiveCategory = nameof(LendaSwapNavPages) });
}

<form method="post" asp-action="Settings" asp-controller="UILendaSwap">
    <div class="sticky-header d-flex align-items-center justify-content-between">
        <h2>@ViewData["Title"]</h2>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>

    <partial name="_StatusMessage" />

    <div class="row">
        <div class="col-xl-10 col-xxl-constrain">
            <h4 class="mb-3">Default Addresses</h4>

            <div class="form-group">
                <label asp-for="DefaultPolygonAddress" class="form-label"></label>
                <input asp-for="DefaultPolygonAddress" class="form-control" placeholder="0x..." />
                <span asp-validation-for="DefaultPolygonAddress" class="text-danger"></span>
                <div class="text-secondary mt-1">
                    Default Polygon address for receiving USDC via Lightning to USDC swaps.
                </div>
            </div>

            <div class="form-group">
                <label asp-for="DefaultArkadeAddress" class="form-label"></label>
                <input asp-for="DefaultArkadeAddress" class="form-control" placeholder="ark1..." />
                <span asp-validation-for="DefaultArkadeAddress" class="text-danger"></span>
                <div class="text-secondary mt-1">
                    Default Arkade address for receiving BTC via Bitcoin onchain to Arkade swaps.
                </div>
            </div>
        </div>
    </div>
</form>
