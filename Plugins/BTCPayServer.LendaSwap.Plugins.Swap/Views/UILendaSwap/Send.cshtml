@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Abstractions.Models
@using BTCPayServer.LendaSwap.Plugins.Swap
@using BTCPayServer.LendaSwap.Plugins.Swap.ViewModels
@model CreateSwapViewModel
@inject IScopeProvider ScopeProvider
@{
    var storeId = ScopeProvider.GetCurrentStoreId();
    Layout = "_Layout";
    ViewData.SetLayoutModel(new LayoutModel(nameof(LendaSwapNavPages.Send), "Send")
        { ActiveCategory = nameof(LendaSwapNavPages) });

    var hasLightning = ViewData["HasLightning"] as bool? ?? false;
    var hasOnchain = ViewData["HasOnchain"] as bool? ?? false;
    var hasOnchainHot = ViewData["HasOnchainHotWallet"] as bool? ?? false;
    var hasAnyWallet = hasLightning || hasOnchain;
}

<form method="post" asp-action="SendCreate" asp-controller="UILendaSwap" asp-route-storeId="@storeId" id="sendForm">
    <div class="sticky-header d-flex align-items-center justify-content-between">
        <h2>@ViewData["Title"]</h2>
        <button type="button" class="btn btn-primary" id="submitBtn" disabled>Send</button>
    </div>

    <partial name="_StatusMessage" />

    @if (!hasOnchain)
    {
        <div class="row">
            <div class="col-xl-8 col-xxl-constrain">
                <div class="alert alert-danger mb-3">
                    <h5 class="alert-heading mb-2">No onchain wallet configured</h5>
                    <p class="mb-0">
                        Configure an <strong>onchain wallet</strong> in your store's wallet settings to use LendaSwap.
                        This is required for swap key derivation.
                    </p>
                </div>
            </div>
        </div>
    }
    else if (!hasLightning)
    {
        <div class="row">
            <div class="col-xl-8 col-xxl-constrain">
                <div class="alert alert-warning mb-3">
                    <p class="mb-0">
                        <strong>Lightning not configured.</strong> Connect a Lightning node in your store settings
                        to enable Lightning-based swaps. Onchain swaps are still available.
                    </p>
                </div>
            </div>
        </div>
    }

    <div class="row">
        <div class="col-xl-8 col-xxl-constrain">

            <div class="bg-tile rounded p-4 mb-4">
                <h4 class="mb-3">I want to send</h4>

                <!-- Source Chain Selection -->
                <div class="form-group mb-3">
                    <label class="form-label">Source</label>
                    <div class="d-flex flex-column gap-2" id="sourceOptions">
                        <label class="d-flex align-items-center gap-3 p-3 rounded border @(hasLightning ? "" : "opacity-50")"
                               style="cursor: @(hasLightning ? "pointer" : "not-allowed");"
                               data-source-chain="Lightning" data-source-token="btc">
                            <input type="radio" name="sourceChoice" value="Lightning"
                                   class="form-check-input mt-0" @(hasLightning ? "checked" : "disabled")
                                   data-source-chain="Lightning" data-source-token="btc" />
                            <div class="flex-grow-1">
                                <span class="fw-semibold">BTC (Lightning)</span>
                                @if (!hasLightning)
                                {
                                    <span class="text-danger ms-2">No Lightning node connected</span>
                                }
                            </div>
                            @if (hasLightning)
                            {
                                <span class="badge bg-success">Auto-pay</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Unavailable</span>
                            }
                        </label>
                        <label class="d-flex align-items-center gap-3 p-3 rounded border @(hasOnchain ? "" : "opacity-50")"
                               style="cursor: @(hasOnchain ? "pointer" : "not-allowed");"
                               data-source-chain="Bitcoin" data-source-token="btc">
                            <input type="radio" name="sourceChoice" value="Bitcoin"
                                   class="form-check-input mt-0" @(!hasLightning && hasOnchain ? "checked" : "")
                                   data-source-chain="Bitcoin" data-source-token="btc" />
                            <div class="flex-grow-1">
                                <span class="fw-semibold">BTC (Onchain)</span>
                            </div>
                            @if (hasOnchainHot)
                            {
                                <span class="badge bg-success">Auto-pay</span>
                            }
                            else if (hasOnchain)
                            {
                                <span class="badge bg-warning text-dark">Manual pay</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Not configured</span>
                            }
                        </label>
                        @* EVM→BTC flows are on the Receive page *@
                    </div>
                </div>

                <!-- Target Chain/Token Selection -->
                <div class="form-group mb-3">
                    <label class="form-label">Receive on</label>
                    <select class="form-select" id="targetSelect">
                        <option value="" data-chain="" data-token="">-- Select target --</option>
                    </select>
                </div>

                <input type="hidden" asp-for="SourceChain" id="sourceChain" />
                <input type="hidden" asp-for="SourceToken" id="sourceToken" />
                <input type="hidden" asp-for="TargetChain" id="targetChain" />
                <input type="hidden" asp-for="TargetToken" id="targetToken" />

                <div class="form-group mb-3">
                    <label asp-for="AmountSats" class="form-label">Amount</label>
                    <div class="input-group">
                        <input asp-for="AmountSats" class="form-control" inputmode="numeric" placeholder="0" id="amountSats" />
                        <span class="input-group-text">sats</span>
                    </div>
                    <span asp-validation-for="AmountSats" class="text-danger"></span>
                    <div id="quoteMinMax" class="text-secondary small mt-1" style="display:none;"></div>
                </div>

                <!-- Quote info -->
                <div id="quoteInfo" class="text-secondary small mb-3" style="display:none;">
                    <span id="quoteReceive" class="fw-semibold"></span>
                    <span class="mx-1">&middot;</span>
                    <span id="quoteFee"></span>
                </div>
                <div id="quoteError" class="text-danger small mb-3" style="display:none;"></div>
                <div id="quoteLoading" class="text-secondary small mb-3" style="display:none;">
                    Fetching quote...
                </div>
            </div>

            <div class="bg-tile rounded p-4 mb-4" id="destinationSection">
                <h4 class="mb-3" id="destinationTitle">Destination</h4>
                <div class="form-group">
                    <label asp-for="ClaimDestination" class="form-label" id="destinationLabel">Destination Address</label>
                    <input asp-for="ClaimDestination" class="form-control" id="claimDestination" placeholder="0x... or ark1..." />
                    <span asp-validation-for="ClaimDestination" class="text-danger"></span>
                    <div class="text-secondary mt-1 small" id="destinationHint">Address where you will receive funds.</div>
                </div>
            </div>

        </div>
    </div>
</form>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel">Confirm Swap</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">You send</dt>
                    <dd class="col-sm-8" id="confirmSend">—</dd>

                    <dt class="col-sm-4">You receive</dt>
                    <dd class="col-sm-8" id="confirmReceive">—</dd>

                    <dt class="col-sm-4">Fees</dt>
                    <dd class="col-sm-8" id="confirmFees">—</dd>

                    <dt class="col-sm-4">Destination</dt>
                    <dd class="col-sm-8 text-break" id="confirmDest">—</dd>
                </dl>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmSendBtn">Confirm &amp; Send</button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var btcTokens = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.BtcTokens));
    var evmTokens = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.EvmTokens));
    console.log('LendaSwap Send: btcTokens=' + btcTokens.length + ', evmTokens=' + evmTokens.length);

    var walletStatus = {
        'Lightning': @(hasLightning ? "true" : "false"),
        'Bitcoin': @(hasOnchain ? "true" : "false")
    };

    var defaultAddresses = {
        'evm': '@Html.Raw(ViewData["DefaultEvmAddress"])',
        'Arkade': '@Html.Raw(ViewData["DefaultArkadeAddress"])'
    };

    // Chain display names
    var chainNames = {
        'Polygon': 'Polygon',
        'Ethereum': 'Ethereum',
        'Arbitrum': 'Arbitrum',
        'Arkade': 'Arkade',
        'Lightning': 'Lightning',
        'Bitcoin': 'Bitcoin'
    };

    var sourceChainInput = document.getElementById('sourceChain');
    var sourceTokenInput = document.getElementById('sourceToken');
    var targetChainInput = document.getElementById('targetChain');
    var targetTokenInput = document.getElementById('targetToken');
    var targetSelect = document.getElementById('targetSelect');
    var amountInput = document.getElementById('amountSats');
    var submitBtn = document.getElementById('submitBtn');
    var quoteInfo = document.getElementById('quoteInfo');
    var quoteReceive = document.getElementById('quoteReceive');
    var quoteFee = document.getElementById('quoteFee');
    var quoteError = document.getElementById('quoteError');
    var quoteLoading = document.getElementById('quoteLoading');
    var quoteMinMax = document.getElementById('quoteMinMax');
    var radios = document.querySelectorAll('input[name="sourceChoice"]');
    var destinationTitle = document.getElementById('destinationTitle');
    var destinationLabel = document.getElementById('destinationLabel');
    var destinationHint = document.getElementById('destinationHint');
    var claimDestination = document.getElementById('claimDestination');
    var sendForm = document.getElementById('sendForm');

    // Confirmation modal elements (bootstrap may load later)
    var confirmModalEl = document.getElementById('confirmModal');
    var confirmModal = null;
    var confirmSend = document.getElementById('confirmSend');
    var confirmReceive = document.getElementById('confirmReceive');
    var confirmFees = document.getElementById('confirmFees');
    var confirmDest = document.getElementById('confirmDest');
    var confirmSendBtn = document.getElementById('confirmSendBtn');

    var lastQuoteData = null;

    // Send page: BTC → EVM/Arkade only. EVM→BTC flows are on the Receive page.
    function getValidTargets(sourceChain) {
        var targets = [];
        if (sourceChain === 'Lightning' || sourceChain === 'Bitcoin') {
            evmTokens.forEach(function (t) {
                targets.push({
                    chain: t.chain,
                    token: t.token_id,
                    label: t.symbol + ' (' + (chainNames[t.chain] || t.chain) + ')',
                    symbol: t.symbol
                });
            });
            targets.push({
                chain: 'Arkade',
                token: 'btc',
                label: 'BTC (Arkade)',
                symbol: 'BTC'
            });
        }
        return targets;
    }

    function populateTargetSelect(sourceChain) {
        var targets = getValidTargets(sourceChain);
        targetSelect.innerHTML = '<option value="" data-chain="" data-token="">-- Select target --</option>';
        targets.forEach(function (t) {
            var opt = document.createElement('option');
            opt.value = t.chain + '|' + t.token;
            opt.dataset.chain = t.chain;
            opt.dataset.token = t.token;
            opt.textContent = t.label;
            targetSelect.appendChild(opt);
        });
    }

    function updateDestinationUI(targetChain) {
        if (targetChain === 'Arkade') {
            destinationTitle.textContent = 'Receive BTC (Arkade)';
            destinationLabel.textContent = 'Arkade Destination Address';
            destinationHint.textContent = 'Arkade address where you will receive BTC.';
            claimDestination.placeholder = 'ark1...';
            claimDestination.value = defaultAddresses['Arkade'] || '';
        } else if (targetChain) {
            var name = chainNames[targetChain] || 'EVM';
            destinationTitle.textContent = 'Receive on ' + name;
            destinationLabel.textContent = name + ' Destination Address';
            destinationHint.textContent = name + ' address (0x...) where you will receive tokens.';
            claimDestination.placeholder = '0x...';
            claimDestination.value = defaultAddresses['evm'] || '';
        }
    }

    function updateSubmitButton() {
        var sourceChain = sourceChainInput.value;
        var targetChain = targetChainInput.value;
        var available = walletStatus[sourceChain] || false;
        submitBtn.disabled = !available || !targetChain;
    }

    function updateSelection(sourceChain) {
        sourceChainInput.value = sourceChain;
        sourceTokenInput.value = 'btc';

        document.querySelectorAll('#sourceOptions label').forEach(function (label) {
            var isSelected = label.dataset.sourceChain === sourceChain;
            if (isSelected) {
                label.classList.add('border-primary', 'bg-primary', 'bg-opacity-10');
            } else {
                label.classList.remove('border-primary', 'bg-primary', 'bg-opacity-10');
            }
        });

        populateTargetSelect(sourceChain);
        updateSubmitButton();
    }

    radios.forEach(function (radio) {
        radio.addEventListener('change', function () {
            updateSelection(this.dataset.sourceChain);
        });
    });

    targetSelect.addEventListener('change', function () {
        var selected = this.options[this.selectedIndex];
        targetChainInput.value = selected.dataset.chain || '';
        targetTokenInput.value = selected.dataset.token || '';
        updateDestinationUI(selected.dataset.chain);
        updateSubmitButton();
        debouncedFetchQuote();
    });

    // Initialize: select first available source and populate targets
    var initialChecked = document.querySelector('input[name="sourceChoice"]:checked');
    if (!initialChecked) {
        // No radio checked — try to check the first non-disabled one
        var firstAvailable = document.querySelector('input[name="sourceChoice"]:not(:disabled)');
        if (firstAvailable) {
            firstAvailable.checked = true;
            initialChecked = firstAvailable;
        }
    }
    if (initialChecked) {
        updateSelection(initialChecked.dataset.sourceChain);
    } else {
        // No wallet at all — still populate targets so user can see what's available
        populateTargetSelect('Lightning');
    }

    var quoteTimeout = null;
    // Map chain name to BTC token_id for quote API
    var btcTokenIdMap = { 'Lightning': 'btc_lightning', 'Bitcoin': 'btc_onchain', 'Arkade': 'btc_arkade' };

    function fetchQuote() {
        var sourceChain = sourceChainInput.value;
        var targetToken = targetTokenInput.value;
        var amount = parseInt(amountInput.value, 10);

        quoteInfo.style.display = 'none';
        quoteError.style.display = 'none';
        quoteLoading.style.display = 'none';
        lastQuoteData = null;

        // Build from/to token_ids
        var from = btcTokenIdMap[sourceChain]; // e.g. 'btc_lightning'
        var to = targetToken; // e.g. 'usdc_eth' (already a token_id from dropdown)
        if (!from || !to || !amount || amount <= 0) return;

        quoteLoading.style.display = '';

        var url = '@Url.Action("GetQuoteApi", "UILendaSwap", new { storeId = "__STOREID__" })'.replace('__STOREID__', '@storeId');
        url += (url.indexOf('?') >= 0 ? '&' : '?') +
            'from=' + encodeURIComponent(from) +
            '&to=' + encodeURIComponent(to) +
            '&amount=' + amount;

        fetch(url, { credentials: 'same-origin' })
            .then(function (r) {
                if (!r.ok) return r.json().then(function (d) { throw new Error(d.error || 'Quote failed'); });
                return r.json();
            })
            .then(function (data) {
                quoteLoading.style.display = 'none';
                quoteInfo.style.display = '';
                lastQuoteData = data;

                if (data.minAmount || data.maxAmount) {
                    amountInput.min = data.minAmount || '';
                    amountInput.max = data.maxAmount || '';
                    quoteMinMax.style.display = '';
                    quoteMinMax.textContent = 'Min: ' + (data.minAmount || 0).toLocaleString() + ' \u00b7 Max: ' + (data.maxAmount || 0).toLocaleString() + ' sats';
                }

                if (data.targetAmount) {
                    quoteReceive.textContent = 'You receive: \u2248 ' + data.targetAmount;
                } else {
                    quoteReceive.textContent = '';
                }
                var totalFeeSats = (data.protocolFee || 0) + (data.networkFee || 0) + (data.gaslessNetworkFee || 0);
                quoteFee.textContent = 'Fee: ' + totalFeeSats.toLocaleString() + ' sats';
            })
            .catch(function (err) {
                quoteLoading.style.display = 'none';
                quoteError.style.display = '';
                quoteError.textContent = err.message || 'Failed to fetch quote';
            });
    }

    function debouncedFetchQuote() {
        if (quoteTimeout) clearTimeout(quoteTimeout);
        quoteTimeout = setTimeout(fetchQuote, 1500);
    }

    amountInput.addEventListener('input', debouncedFetchQuote);

    if (amountInput.value && parseInt(amountInput.value, 10) > 0) {
        fetchQuote();
    }

    // Confirmation modal flow
    submitBtn.addEventListener('click', function () {
        var amount = parseInt(amountInput.value, 10);
        if (!amount || amount <= 0) {
            amountInput.focus();
            return;
        }
        if (!claimDestination.value) {
            claimDestination.focus();
            return;
        }

        if (amountInput.min && amount < parseInt(amountInput.min, 10)) {
            quoteError.style.display = '';
            quoteError.textContent = 'Amount is below the minimum of ' + parseInt(amountInput.min, 10).toLocaleString() + ' sats.';
            amountInput.focus();
            return;
        }
        if (amountInput.max && amount > parseInt(amountInput.max, 10)) {
            quoteError.style.display = '';
            quoteError.textContent = 'Amount exceeds the maximum of ' + parseInt(amountInput.max, 10).toLocaleString() + ' sats.';
            amountInput.focus();
            return;
        }

        var totalFees = lastQuoteData ? ((lastQuoteData.protocolFee || 0) + (lastQuoteData.networkFee || 0) + (lastQuoteData.gaslessNetworkFee || 0)) : 0;
        confirmSend.textContent = amount.toLocaleString() + ' sats';
        confirmFees.textContent = totalFees.toLocaleString() + ' sats';
        confirmReceive.textContent = lastQuoteData && lastQuoteData.targetAmount ? lastQuoteData.targetAmount : '\u2014';
        confirmDest.textContent = claimDestination.value;

        if (!confirmModal && typeof bootstrap !== 'undefined') confirmModal = new bootstrap.Modal(confirmModalEl);
        if (confirmModal) confirmModal.show();
    });

    confirmSendBtn.addEventListener('click', function () {
        if (confirmModal) confirmModal.hide();
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Creating swap...';
        sendForm.submit();
    });
})();
</script>
